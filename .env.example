# App
APP_NAME=TradingBot
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
API_V1_STR=/api/v1
ALLOWED_HOSTS=["localhost","127.0.0.1","your-vps-ip"]

# Database
DATABASE_URL=postgresql+asyncpg://tradingbot:password@postgres:5432/tradingbot_db
DATABASE_SYNC_URL=postgresql://tradingbot:password@postgres:5432/tradingbot_db

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bybit
BYBIT_API_KEY=your-bybit-api-key
BYBIT_API_SECRET=your-bybit-api-secret
BYBIT_BASE_URL=https://api.bybit.com

# Polymarket
POLYMARKET_API_KEY=your-polymarket-api-key
POLYMARKET_API_SECRET=your-polymarket-api-secret
POLYMARKET_API_PASSPHRASE=your-polymarket-api-passphrase
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# Trading Config
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_STOP_LOSS=103500
DEFAULT_TAKE_PROFIT=107000
DEFAULT_RISK_PERCENT=1.0
MAX_OPEN_TRADES=5
LEVERAGE=10

# DeepSeek Cloud API (recommended — get key at platform.deepseek.com)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Ollama fallback (only used if DEEPSEEK_API_KEY is empty)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-r1:7b

AI_ANALYSIS_INTERVAL=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/tradingbot/app.log

#TELEGRAM
PUBLIC_KEY_TELEGRAM=
PRODUCTION_CONFIG=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Security
CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]
RATE_LIMIT_PER_MINUTE=60
MAX_LOGIN_ATTEMPTS=5

# Monitoring
PROMETHEUS_ENABLED=true
